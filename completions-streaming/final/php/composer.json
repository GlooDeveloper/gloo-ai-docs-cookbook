{
  "name": "gloo/completions-streaming",
  "description": "Streaming AI Responses in Real Time - PHP implementation",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": ">=7.0",
    "vlucas/phpdotenv": ">=5.0"
  },
  "autoload": {
    "psr-4": {
      "GlooStreaming\\": "src/"
    }
  },
  "scripts": {
    "start": "php src/index.php",
    "proxy": "php -S localhost:3001 src/Proxy/Server.php"
  }
}

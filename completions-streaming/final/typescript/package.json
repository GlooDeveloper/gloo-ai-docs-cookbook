{
  "name": "completions-streaming-typescript",
  "version": "1.0.0",
  "description": "Streaming AI Responses in Real Time - TypeScript implementation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node --esm src/index.ts",
    "proxy": "ts-node --esm src/proxy/server.ts",
    "dev": "ts-node --esm src/index.ts",
    "test:step1": "node --loader ts-node/esm --no-warnings tests/step1-auth.test.ts",
    "test:step2": "node --loader ts-node/esm --no-warnings tests/step2-sse-parsing.test.ts",
    "test:step3": "node --loader ts-node/esm --no-warnings tests/step3-accumulation.test.ts",
    "test:step4": "node --loader ts-node/esm --no-warnings tests/step4-error-handling.test.ts",
    "test:step5": "node --loader ts-node/esm --no-warnings tests/step5-renderer.test.ts"
  },
  "dependencies": {
    "dotenv": ">=16.0.0",
    "express": ">=4.18.0"
  },
  "devDependencies": {
    "typescript": ">=5.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0"
  }
}

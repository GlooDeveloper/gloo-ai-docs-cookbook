# Gloo AI API Credentials
# Get these from the API Credentials page in Gloo AI Studio
GLOO_CLIENT_ID=your_client_id_here
GLOO_CLIENT_SECRET=your_client_secret_here

# Your publisher tenant name (required for publisher-scoped recommendations)
GLOO_TENANT=your_tenant_name_here

# Content collection (default: GlooProd)
GLOO_COLLECTION=GlooProd

# Optional: default number of items to return (default: 5)
DEFAULT_ITEM_COUNT=5

# Optional: port for the proxy server (default: 3000)
PORT=3000
